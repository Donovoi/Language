FROM python:3.12-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        ffmpeg \
        git \
        git-lfs \
        libsndfile1 \
    && git lfs install --skip-repo \
    && rm -rf /var/lib/apt/lists/*

COPY docker/dev/requirements-audio-eval.txt /tmp/requirements-audio-eval.txt
COPY docker/dev/requirements-audio-eval-pyannote.txt /tmp/requirements-audio-eval-pyannote.txt
RUN python -m pip install --upgrade pip \
    && python -m pip install --no-cache-dir -r /tmp/requirements-audio-eval.txt \
    && python -m pip install --no-cache-dir -r /tmp/requirements-audio-eval-pyannote.txt

WORKDIR /workspace

CMD ["bash"]
