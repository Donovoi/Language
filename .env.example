# Gateway runtime defaults for local development.
# For container runs, override LANGUAGE_GATEWAY_HOST=0.0.0.0.
LANGUAGE_GATEWAY_HOST=127.0.0.1
LANGUAGE_GATEWAY_PORT=8000
LANGUAGE_GATEWAY_LOG_LEVEL=info

# Optional Flutter compile-time override.
# Leave blank to keep the built-in platform defaults.
FIELD_APP_API_BASE_URL=