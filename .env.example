# Gateway runtime defaults for local development.
# For container runs, override LANGUAGE_GATEWAY_HOST=0.0.0.0.
LANGUAGE_GATEWAY_HOST=127.0.0.1
LANGUAGE_GATEWAY_PORT=8000
LANGUAGE_GATEWAY_LOG_LEVEL=info
LANGUAGE_GATEWAY_PRIORITIZER_BACKEND=auto
LANGUAGE_GATEWAY_RUST_RANKER_BIN=
LANGUAGE_GATEWAY_RUST_RANKER_TIMEOUT_MS=4000

# Optional real translation adapter (LibreTranslate-compatible).
# Set the provider to libretranslate and supply a base URL to enable it.
LANGUAGE_GATEWAY_TRANSLATION_PROVIDER=disabled
LANGUAGE_GATEWAY_TRANSLATION_BASE_URL=
LANGUAGE_GATEWAY_TRANSLATION_API_KEY=
LANGUAGE_GATEWAY_TRANSLATION_TARGET_LANGUAGE=en
LANGUAGE_GATEWAY_TRANSLATION_TIMEOUT_MS=4000

# Optional Flutter compile-time override.
# Leave blank to keep the built-in platform defaults.
FIELD_APP_API_BASE_URL=